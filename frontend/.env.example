# Private hosted demo passcode (Optional)
# If set, blocks public generation calls until password key is entered on frontend
SIGNALFLOW_ACCESS_KEY=

# Cloud AI Model Provider API Keys (Bring Your Own Key)
# Leave empty if not using a specific provider; the system will fallback safely
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Hugging Face token (Optional)
HF_TOKEN=

# Local SLM/LLM endpoint bases (Ollama / LM Studio default values)
OLLAMA_BASE_URL=http://localhost:11434/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Custom OpenAI-compatible gateway endpoints configuration
CUSTOM_OPENAI_BASE_URL=
CUSTOM_OPENAI_API_KEY=

# Defaults for automatic bypass selections
DEFAULT_MODEL_PROVIDER=prompt
DEFAULT_MODEL_NAME=
