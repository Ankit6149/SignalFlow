# ═══════════════════════════════════════════════════
# SignalFlow Studio — Safe Environment Configurations
# ═══════════════════════════════════════════════════
# WARNING: 
# 1. NEVER prefix provider secrets or credentials with "NEXT_PUBLIC_" as this will expose them to client browsers.
# 2. NEVER commit your actual ".env.local" file to Git repository source control.
# 3. Hosted public deployments should keep the owner access locked by configuring SIGNALFLOW_ACCESS_KEY.

# ── App Security & Modes ──
# Optional: Set a password key to protect administrative routes on hosted deployments
SIGNALFLOW_ACCESS_KEY=

# Set to "true" on public hosted instances to hide owner connections and enforce BYOK
SIGNALFLOW_PUBLIC_HOSTED=true

# ── AI Model Providers (Owner / Private Deployments Only) ──
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# ── Social Media OAuth Credentials (Owner / Private Deployments Only) ──
# LinkedIn: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# X/Twitter: https://developer.twitter.com/en/portal/dashboard
X_CLIENT_ID=
X_CLIENT_SECRET=

# Reddit: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Token Encryption Salt (derives from SIGNALFLOW_ACCESS_KEY if blank)
SOCIAL_ENCRYPTION_KEY=
