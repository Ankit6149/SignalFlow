# ═══════════════════════════════════════════════════
# SignalFlow Studio — Environment Configuration
# ═══════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values.

# ── AI Model Providers ──
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
HF_TOKEN=

# ── Local Model Providers ──
OLLAMA_BASE_URL=http://localhost:11434/v1
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# ── Custom OpenAI-compatible Gateway ──
CUSTOM_OPENAI_BASE_URL=
CUSTOM_OPENAI_API_KEY=

# ── Default Model Settings ──
DEFAULT_MODEL_PROVIDER=template
DEFAULT_MODEL_NAME=

# ── App Security ──
SIGNALFLOW_ACCESS_KEY=

# ── Social Media OAuth (for direct posting) ──
# LinkedIn: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# X/Twitter: https://developer.twitter.com/en/portal/dashboard
X_CLIENT_ID=
X_CLIENT_SECRET=

# Reddit: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── Token Encryption ──
# A 32+ character string used to encrypt stored OAuth tokens at rest.
# If not set, derives from SIGNALFLOW_ACCESS_KEY.
SOCIAL_ENCRYPTION_KEY=

# ── OAuth Callback Base URL ──
# Set to your deployed domain for production (e.g. https://your-app.vercel.app)
# Defaults to http://localhost:3000 for local development.
NEXTAUTH_URL=http://localhost:3000
