{
  "manifest_version": 3,
  "name": "SignalFlow Studio Clip Helper",
  "version": "1.0",
  "description": "Quickly record screen walkthroughs or capture mockups and send details to SignalFlow Studio.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
